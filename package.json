{
  "name": "hive-ui",
  "private": true,
  "version": "0.10.11",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.functions.json --pretty false",
    "check": "npm run verify:lock && npm run verify:source && npm run test:security && npm run test:ux-contract && npm run typecheck && npm run lint && npm run test:unit && npm run build && npm run verify:dist",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "verify:dist": "node scripts/verify-dist.mjs",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs dist",
    "verify:lock": "node scripts/verify-lockfile.mjs",
    "verify:source": "node scripts/verify-source.mjs",
    "test:security": "rm -rf .security-test && tsc -p tsconfig.security-test.json && node --test scripts/security.test.mjs",
    "test:ux-contract": "node --test scripts/ux-contract.test.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router": "^8.0.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260706.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.10"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  }
}
