{
  "name": "hive-ui",
  "private": true,
  "version": "0.9.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.functions.json --pretty false",
    "check": "npm run verify:lock && npm run verify:source && npm run test:security && npm run typecheck && npm run lint && npm run build && npm run verify:dist",
    "verify:dist": "node scripts/verify-dist.mjs",
    "verify:lock": "node scripts/verify-lockfile.mjs",
    "verify:source": "node scripts/verify-source.mjs",
    "test:security": "rm -rf .security-test && tsc -p tsconfig.security-test.json && node --test scripts/security.test.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router": "^7.17.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260615.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  }
}
